{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CALC_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "sanitize",
      "inherits": "debug",
      "cacheVariables": { "CALC_ENABLE_SANITIZERS": "ON" }
    },
    {
      "name": "ci",
      "inherits": "debug",
      "cacheVariables": { "CALC_WARNINGS_AS_ERRORS": "ON" }
    },
    {
      "name": "coverage",
      "inherits": "debug",
      "cacheVariables": { "CALC_ENABLE_COVERAGE": "ON" }
    },
    {
      "name": "gui",
      "inherits": "debug",
      "cacheVariables": {
        "CALC_BUILD_GUI": "ON",
        "CALC_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "sanitize", "configurePreset": "sanitize" },
    { "name": "ci", "configurePreset": "ci" },
    { "name": "coverage", "configurePreset": "coverage" },
    { "name": "gui", "configurePreset": "gui" }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "sanitize",
      "configurePreset": "sanitize",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ci",
      "configurePreset": "ci",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": { "outputOnFailure": true }
    }
  ]
}
